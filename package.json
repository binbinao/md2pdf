{
  "name": "md2pdf",
  "version": "0.1.0",
  "description": "Convert Markdown to PDF from the CLI",
  "bin": {
    "md2pdf": "./bin/md2pdf.js"
  },
  "main": "src/converter.js",
  "scripts": {
    "start": "node bin/md2pdf.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/ bin/ --max-warnings=0",
    "format": "prettier --write 'src/**/*.js' 'bin/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'bin/**/*.js' 'tests/**/*.js'"
  },
  "dependencies": {
    "md-to-pdf": "^5.2.5",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "markdown",
    "pdf",
    "cli",
    "converter"
  ]
}
